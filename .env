# Environment Variables for AMASHIA MD BOT V.2

# Bot Configuration
BOT_PREFIX=.
BOT_NAME=AMASHIA MD BOT V.2
OWNER_NUMBER=50931234567

# Server Configuration
PORT=3000
NODE_ENV=production

# Features
ENABLE_AUTO_REPLY=true
ENABLE_ANTI_CALL=true
ENABLE_FAKE_TYPING=true
ENABLE_AUTO_STATUS_SEEN=true

# Sessions Directory
SESSIONS_DIR=./sessions
